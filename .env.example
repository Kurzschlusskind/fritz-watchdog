# FritzWatchdog environment configuration
# Copy this file to .env and fill in your actual values.
# docker-compose will load .env automatically.

# ── FRITZ!Box connection ──────────────────────────────────────────────────────

# IP address of the FRITZ!Box gateway
FRITZ_ADDRESS=192.168.178.1

# TR-064 SOAP port (default: 49000)
FRITZ_PORT=49000

# TR-064 user account (create a dedicated account with sufficient permissions)
FRITZ_USER=watchdog

# TR-064 password (REQUIRED — no default)
FRITZ_PASSWORD=CHANGEME

# ── Probe configuration ───────────────────────────────────────────────────────

# Probe interval in seconds (how often to check connectivity)
PROBE_INTERVAL=60

# Number of consecutive failures before triggering recovery
FAIL_THRESHOLD=3

# Comma-separated list of IP addresses to send ICMP echo requests to
ICMP_TARGETS=8.8.8.8,1.1.1.1

# DNS server IP for DNS probe
DNS_TARGET=9.9.9.9

# Hostname to resolve in the DNS probe
DNS_QUERY=google.com

# UDP port for DNS probe
DNS_PORT=53

# ── Recovery configuration ────────────────────────────────────────────────────

# Seconds to wait after Phase 1 (ForceTermination / PPPoE re-negotiation) before re-probing
RECONNECT_HOLD=120

# Seconds to wait after Phase 2 (full reboot) before re-probing
REBOOT_HOLD=180

# Minimum seconds between consecutive recovery actions (cooldown)
ACTION_COOLDOWN=600

# Maximum number of Phase 2 escalations allowed per 24-hour window
MAX_ESCALATIONS=5

# ── Scheduled maintenance ─────────────────────────────────────────────────────

# Weekly full reboot schedule — format: DAY/HH:MM
# Days: MON TUE WED THU FRI SAT SUN
# Example: TUE/04:00  →  every Tuesday at 04:00
SCHEDULED_REBOOT=TUE/04:00

# ── Logging ───────────────────────────────────────────────────────────────────

# Directory for persistent log files
LOG_DIR=/var/log/fritzwatchdog

# Seconds between periodic NOMINAL status log entries (when connectivity is healthy)
NOMINAL_INTERVAL=600
